# ── Gradle build outputs ──────────────────────────────────────────────────
.gradle/
build/
app/build/
**/build/

# ── Local configuration (machine-specific, never commit) ──────────────────
local.properties

# ── Android Studio / IntelliJ ─────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.DS_Store
captures/
.externalNativeBuild/
.cxx/

# ── Keystore & signing secrets ────────────────────────────────────────────
*.jks
*.keystore
keystore.properties
signing.properties

# ── Model files (.pte binaries — large, generated by export scripts) ──────
*.pte
app/src/main/assets/models/

# ── Large model artifacts pushed to device storage via adb, not bundled in
# the APK (AGP's asset packaging can't handle files over ~2GB) ─────────────
local_models/

# ── ExecuTorch AAR (downloaded separately, not source) ────────────────────
app/executorch-android.aar
app/libs/*.aar
app/libs/*.so

# ── FAISS prebuilt libraries ──────────────────────────────────────────────
app/faiss/

# ── Python virtualenvs & caches ───────────────────────────────────────────
venv/
.venv/
__pycache__/

# ── ExecuTorch source checkout (built from source, not vendored) ──────────
executorch/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/

# ── HuggingFace model cache (downloaded by export scripts) ────────────────
~/.cache/huggingface/
scripts/__pycache__/

# ── LoRA adapter outputs ──────────────────────────────────────────────────
*.bin
lora_adapter*.bin

# ── RAG index files (built at runtime on device) ──────────────────────────
*.faiss
kb_meta.txt

# ── APK / AAB release artifacts ───────────────────────────────────────────
*.apk
*.aab
*.ap_

# ── ProGuard mapping (keep per release, not in general commits) ───────────
mapping.txt

# ── macOS ─────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
